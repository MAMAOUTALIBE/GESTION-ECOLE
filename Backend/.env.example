# =============================================================================
# GESTION-EE — Backend Python · variables d'environnement
# Copier en .env et remplir les valeurs réelles. NE JAMAIS COMMITER LE .env
# =============================================================================

# --- Application ---
APP_NAME="GESTION-EE API"
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000

# --- Sécurité ---
JWT_SECRET=change-me-with-a-long-random-secret-256-bits-minimum
JWT_ALGORITHM=HS256
# 8h matches the NestJS default (JWT_EXPIRES_IN=8h) — keeps frontend compatibility.
JWT_ACCESS_TOKEN_TTL_MINUTES=480
JWT_REFRESH_TOKEN_TTL_DAYS=7

# --- CORS ---
# Liste séparée par virgules, ex: http://localhost:4200,https://gestion-ee.gov.gn
CORS_ORIGINS=http://localhost:4200

# --- Base de données PostgreSQL (PostGIS requis) ---
# Format async: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://gestionee:gestionee@localhost:5432/gestionee
# URL synchrone pour Alembic
DATABASE_URL_SYNC=postgresql+psycopg2://gestionee:gestionee@localhost:5432/gestionee
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# --- Redis (cache + Celery broker) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- QR & vérification publique ---
QR_PUBLIC_BASE_URL=http://localhost:4200/verify

# --- Stockage objets (MinIO en dev, S3 en prod) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=gestionee-documents
S3_BUCKET_REPORTS=gestionee-bulletins
S3_REGION=us-east-1

# --- Notifications (laisser vide en dev) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ORANGE_API_KEY=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
FCM_SERVER_KEY=

# --- Observabilité ---
SENTRY_DSN=
PROMETHEUS_ENABLED=true
